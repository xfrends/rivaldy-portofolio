ADMIN_PASSWORD=change-this-password
# Optional. Defaults to "admin" if empty.
ADMIN_USERNAME=admin
# Optional. Defaults to ADMIN_PASSWORD if empty.
ADMIN_SESSION_SECRET=
SITE_URL=https://rivaldy-portfolio.pages.dev

# Cloudflare resource names/IDs for setup reference.
# Runtime bindings are configured in Cloudflare Pages settings and wrangler.jsonc.
CLOUDFLARE_D1_DATABASE_NAME=rivaldy-portfolio-cms
CLOUDFLARE_D1_DATABASE_ID=replace-with-cloudflare-d1-database-id
CLOUDFLARE_R2_BUCKET_NAME=rivaldy-gallery
CLOUDFLARE_KV_SESSION_NAMESPACE_ID=replace-with-session-kv-namespace-id
CLOUDFLARE_KV_ANALYTICS_NAMESPACE_ID=replace-with-analytics-kv-namespace-id
