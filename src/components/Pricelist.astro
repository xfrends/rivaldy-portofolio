---
// Pricelist.astro
import siteConfig from '../../site.config.mjs';

// Ambil URL WhatsApp dari konfigurasi situs yang sama dengan Footer
const waLinkStr = siteConfig.socialLinks.find(link => link.name === 'WhatsApp')?.url || 'https://wa.me/';

const getWaLink = (paket: string, harga: string) => {
  const message = `Halo, saya tertarik dengan paket foto ${paket} (${harga}). Bisa minta info lebih lanjut?`;
  return `${waLinkStr}?text=${encodeURIComponent(message)}`;
};
---

<section class="py-20 md:py-24 bg-white" id="pricelist">
  <div class="container-custom">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4 font-brand">Pricelist</h2>
      <p class="text-gray-600 text-lg">Choose the perfect photography package for your special moments.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {/* Basic Package */}
      <div class="flex flex-col p-8 bg-white rounded-lg border border-gray-200 hover:border-black transition-colors duration-300">
        <div class="mb-6 text-center border-b border-gray-100 pb-6">
          <h3 class="text-xl font-semibold mb-2">Basic</h3>
          <div class="text-3xl font-bold font-playfair">
            275K
          </div>
        </div>
        <ul class="flex flex-col gap-4 text-gray-600 flex-grow mb-8 text-sm">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-black shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Photo session 1 jam (Include foto keluarga, foto teman, foto individu - lebih banyak foto individu)</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-black shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Best Soft file & selection edited send by Google Drive (same day)</span>
          </li>
        </ul>
        <a href={getWaLink('Basic', '275K')} target="_blank" rel="noopener noreferrer" class="w-full py-3 px-6 text-center border-2 border-black rounded-md hover:bg-black hover:text-white transition-all duration-300 text-sm md:text-base font-medium">Book Basic</a>
      </div>

      {/* Premium Package */}
      <div class="flex flex-col p-8 bg-white rounded-lg border border-gray-200 hover:border-black transition-colors duration-300">
        <div class="mb-6 text-center border-b border-gray-100 pb-6">
          <h3 class="text-xl font-semibold mb-2">Premium</h3>
          <div class="text-3xl font-bold font-playfair">
            330K
          </div>
        </div>
        <ul class="flex flex-col gap-4 text-gray-600 flex-grow mb-8 text-sm">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-black shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Photo Session 1 jam (Include foto keluarga, foto teman, foto individu)</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-black shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"></path>
            </svg>
            <span>All soft file mentahan & Edited Request send by Google Drive</span>
          </li>
        </ul>
        <a href={getWaLink('Premium', '330K')} target="_blank" rel="noopener noreferrer" class="w-full py-3 px-6 text-center border-2 border-black rounded-md hover:bg-black hover:text-white transition-all duration-300 text-sm md:text-base font-medium">Book Premium</a>
      </div>

      {/* Pertamax Package */}
      <div class="flex flex-col p-8 bg-gray-50 rounded-lg border-2 border-black hover:shadow-lg transition-all duration-300 relative transform hover:-translate-y-1">
        <div class="absolute top-0 right-0 bg-black text-white text-[10px] uppercase tracking-wider font-bold px-3 py-1 rounded-bl-lg">
          Popular
        </div>
        <div class="mb-6 text-center border-b border-gray-200 pb-6">
          <h3 class="text-xl font-semibold mb-2">Pertamax</h3>
          <div class="text-3xl font-bold font-playfair">
            380K
          </div>
        </div>
        <ul class="flex flex-col gap-4 text-gray-700 flex-grow mb-8 text-sm">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-black shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Photo Session 1 Jam 45 menit</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-black shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"></path>
            </svg>
            <span>All soft file mentahan & Req edit send by Google Drive</span>
          </li>
        </ul>
        <a href={getWaLink('Pertamax', '380K')} target="_blank" rel="noopener noreferrer" class="w-full py-3 px-6 text-center bg-black text-white border-2 border-black rounded-md hover:bg-gray-800 hover:border-gray-800 transition-all duration-300 text-sm md:text-base font-medium shadow-md">Book Pertamax</a>
      </div>

      {/* Exclusive Package */}
      <div class="flex flex-col p-8 bg-white rounded-lg border border-gray-200 hover:border-black transition-colors duration-300">
        <div class="mb-6 text-center border-b border-gray-100 pb-6">
          <h3 class="text-xl font-semibold mb-2 text-black">Exclusive</h3>
          <div class="text-3xl font-bold font-playfair">
            550K
          </div>
        </div>
        <ul class="flex flex-col gap-4 text-gray-600 flex-grow mb-8 text-sm">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-black shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Photo Session Fleksibel</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-black shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Fotografer membawa aksesoris 2 Lightning, 1 Balon Fire</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-black shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"></path>
            </svg>
            <span>Include Foto keluarga, foto dengan teman, foto individu</span>
          </li>
        </ul>
        <a href={getWaLink('Exclusive', '550K')} target="_blank" rel="noopener noreferrer" class="w-full py-3 px-6 text-center border-2 border-black rounded-md hover:bg-black hover:text-white transition-all duration-300 text-sm md:text-base font-medium">Book Exclusive</a>
      </div>
    </div>
  </div>
</section>
