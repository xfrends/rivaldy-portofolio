---
import siteConfig from '../../site.config.mjs';
import type { PricelistPackage } from '../lib/siteCms';

interface Props {
	packages: PricelistPackage[];
}

const { packages } = Astro.props;
const visiblePackages = packages.filter((pkg) => pkg.enabled);

const waLinkStr = siteConfig.socialLinks.find((link) => link.name === 'WhatsApp')?.url || 'https://wa.me/';

const getWaLink = (paket: string, harga: string) => {
	const message = `Halo, saya tertarik dengan paket foto ${paket} (${harga}). Bisa minta info lebih lanjut?`;
	return `${waLinkStr}?text=${encodeURIComponent(message)}`;
};
---

<section class="py-20 md:py-24 bg-white" id="pricelist">
	<div class="container-custom">
    <div 
      class="max-w-3xl mx-auto text-center mb-16 transition-all duration-1000 ease-out"
      x-data="{ shown: false }" 
      x-intersect.once="shown = true" 
      :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'"
    >
      <h2 class="text-3xl md:text-4xl font-playfair font-normal mb-4 tracking-wide text-black">Our Packages</h2>
      <div class="w-12 h-[1px] bg-black mx-auto mb-6"></div>
      <p class="text-gray-500 font-light text-lg">Choose the perfect photography package for your special moments.</p>
    </div>

		<div 
			class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8"
			x-data="{ shown: false }" 
			x-intersect.once="shown = true"
		>
			{
				visiblePackages.map((pkg, index) => (
					<div 
						class={`flex flex-col p-8 rounded-lg transition-all duration-700 ease-out ${
						pkg.popular
							? 'relative transform border-2 border-black bg-gray-50 hover:-translate-y-2 hover:shadow-xl'
							: 'border border-gray-200 bg-white hover:border-black hover:-translate-y-1 hover:shadow-lg'
					}`}
						:class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'"
						style={`transition-delay: ${index * 150}ms;`}
					>
						{pkg.popular && (
							<div class="absolute top-0 right-0 rounded-bl-lg bg-black px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-white">
								Popular
							</div>
						)}
						<div class={`mb-6 border-b pb-6 text-center ${pkg.popular ? 'border-gray-200' : 'border-gray-100'}`}>
							<h3 class="mb-2 text-xl font-semibold text-black">{pkg.name}</h3>
							<div class="font-playfair text-3xl font-bold">{pkg.price}</div>
						</div>
						<ul class={`mb-8 flex flex-grow flex-col gap-4 text-sm ${pkg.popular ? 'text-gray-700' : 'text-gray-600'}`}>
							{pkg.features.map((feature) => (
								<li class="flex items-start gap-3">
									<svg class="mt-0.5 h-5 w-5 shrink-0 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" />
									</svg>
									<span>{feature}</span>
								</li>
							))}
						</ul>
						<a
							href={getWaLink(pkg.name, pkg.price)}
							target="_blank"
							rel="noopener noreferrer"
							class={`w-full rounded-md border-2 border-black px-6 py-3 text-center text-sm font-medium transition-all duration-300 md:text-base ${
								pkg.popular
									? 'bg-black text-white shadow-md hover:border-gray-800 hover:bg-gray-800'
									: 'hover:bg-black hover:text-white'
							}`}
						>
							Book {pkg.name}
						</a>
					</div>
				))
			}
		</div>
	</div>
</section>
