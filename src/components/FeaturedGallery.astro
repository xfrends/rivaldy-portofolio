---
import PhotoGrid from './PhotoGrid.astro';
import { featuredCollectionId, getImages } from '../data/imageStore';
import { getRuntimeEnv } from '../lib/cloudflare';

const images = await getImages({
	collection: featuredCollectionId,
	runtimeEnv: getRuntimeEnv(Astro.locals),
});
---

<div class="container-custom py-24">
	<div 
		class="max-w-3xl mx-auto text-center mb-20 transition-all duration-1000 ease-out"
		x-data="{ shown: false }" 
		x-intersect.once="shown = true" 
		:class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'"
	>
		<h2 class="text-3xl md:text-4xl font-playfair font-normal mb-4 tracking-wide text-black">Best Selection Works</h2>
		<div class="w-12 h-[1px] bg-black mx-auto mb-6"></div>
		<p class="text-gray-500 font-light text-lg">A selection of my best photographs from moments of achievement and celebration.</p>
	</div>

	<!-- Adding a subtle fade-in animation on scroll -->
	<div 
		x-data="{ shown: false }" 
		x-intersect.once="shown = true"
		:class="shown ? 'opacity-100' : 'opacity-0'"
		class="transition-opacity duration-1000 ease-in-out"
	>
		<PhotoGrid images={images} />
	</div>
</div>
