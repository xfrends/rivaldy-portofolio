---
import type { PricelistPackage } from '../../lib/siteCms';
import { withBase } from '../../lib/urls';

interface Props {
	mode: 'create' | 'update';
	pkg?: PricelistPackage;
}

const { mode, pkg } = Astro.props;
const isUpdate = mode === 'update' && pkg;
---

<form action={withBase('api/admin/pricelist')} method="post" class="space-y-5">
	<input type="hidden" name="action" value={mode} />
	{isUpdate && <input type="hidden" name="originalId" value={pkg.id} />}

	<div class="grid gap-4 md:grid-cols-2">
		<label class="block">
			<span class="text-sm font-medium text-zinc-800">Package ID</span>
			<input
				name="id"
				type="text"
				value={pkg?.id || ''}
				placeholder="basic"
				class="mt-2 w-full rounded-md border border-zinc-300 px-4 py-3 text-base outline-none focus:border-zinc-900"
			/>
		</label>
		<label class="block">
			<span class="text-sm font-medium text-zinc-800">Package Name</span>
			<input
				name="name"
				type="text"
				value={pkg?.name || ''}
				required
				class="mt-2 w-full rounded-md border border-zinc-300 px-4 py-3 text-base outline-none focus:border-zinc-900"
			/>
		</label>
	</div>

	<div class="grid gap-4 md:grid-cols-2">
		<label class="block">
			<span class="text-sm font-medium text-zinc-800">Price</span>
			<input
				name="price"
				type="text"
				value={pkg?.price || ''}
				placeholder="275K"
				required
				class="mt-2 w-full rounded-md border border-zinc-300 px-4 py-3 text-base outline-none focus:border-zinc-900"
			/>
		</label>
		<label class="block">
			<span class="text-sm font-medium text-zinc-800">Sort Order</span>
			<input
				name="sortOrder"
				type="number"
				value={pkg?.sortOrder ?? 0}
				class="mt-2 w-full rounded-md border border-zinc-300 px-4 py-3 text-base outline-none focus:border-zinc-900"
			/>
		</label>
	</div>

	<label class="block">
		<span class="text-sm font-medium text-zinc-800">Features</span>
		<textarea
			name="features"
			rows="8"
			placeholder="Tulis satu fitur per baris"
			required
			class="mt-2 w-full rounded-md border border-zinc-300 px-4 py-3 text-base outline-none focus:border-zinc-900"
		>{pkg?.features.join('\n') || ''}</textarea>
	</label>

	<div class="flex flex-wrap items-center gap-3">
		<label class="flex items-center gap-3 rounded-md border border-zinc-200 px-4 py-3">
			<input name="enabled" type="checkbox" checked={pkg?.enabled ?? true} class="h-5 w-5 accent-zinc-950" />
			<span class="text-sm font-medium text-zinc-800">Show Package</span>
		</label>
		<label class="flex items-center gap-3 rounded-md border border-zinc-200 px-4 py-3">
			<input name="popular" type="checkbox" checked={pkg?.popular ?? false} class="h-5 w-5 accent-zinc-950" />
			<span class="text-sm font-medium text-zinc-800">Popular</span>
		</label>
		<button type="submit" class="ml-auto rounded-md bg-zinc-950 px-5 py-3 text-sm font-semibold text-white">
			{isUpdate ? 'Save Package' : 'Create Package'}
		</button>
		{
			isUpdate && (
				<button
					type="submit"
					name="action"
					value="delete"
					class="rounded-md border border-red-200 px-5 py-3 text-sm font-medium text-red-700"
				>
					Delete Package
				</button>
			)
		}
	</div>
</form>
