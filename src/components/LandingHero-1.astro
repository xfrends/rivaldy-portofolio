---
import siteConfig from '../../site.config.mjs';
import { withBase } from '../lib/urls';

const owner = siteConfig.owner;
const heroSubtitles = [
	'Your Graduation Story',
	'Merayakan Gelar, Mengabadikan Moment',
	'Frame Your Achievement',
];
---

<div class="absolute left-0 right-0 z-0">
	<div class="text-center mb-12 relative z-10">
		<h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight">
			<span class="font-brand">{owner}</span> Photography
		</h1>
		<p
			class="hero-subtitle-rotator mt-4 text-base md:text-lg text-gray-700"
			aria-label="Your Graduation Story, Merayakan Gelar, Mengabadikan Moment, Frame Your Achievement"
		>
			{heroSubtitles.map((subtitle) => <span>{subtitle}</span>)}
		</p>
		<a
			href={withBase('collections')}
			class="mt-8 inline-block px-6 py-3 border-2 border-black rounded-md
                      hover:bg-black hover:text-white transition-all duration-300
                      text-sm md:text-base font-medium
                      transform hover:scale-105 active:scale-95"
		>
			View Gallery
		</a>
	</div>
</div>

<style>
	.hero-subtitle-rotator {
		display: grid;
		min-height: 1.75em;
	}

	.hero-subtitle-rotator span {
		animation: heroSubtitleFade 9s infinite;
		grid-area: 1 / 1;
		opacity: 0;
	}

	.hero-subtitle-rotator span:nth-child(2) {
		animation-delay: 3s;
	}

	.hero-subtitle-rotator span:nth-child(3) {
		animation-delay: 6s;
	}

	@keyframes heroSubtitleFade {
		0%,
		8% {
			opacity: 0;
			transform: translateY(0.25rem);
		}

		12%,
		29% {
			opacity: 1;
			transform: translateY(0);
		}

		33%,
		100% {
			opacity: 0;
			transform: translateY(-0.25rem);
		}
	}
</style>
