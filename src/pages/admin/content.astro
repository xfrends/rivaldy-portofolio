---
import MainLayout from '../../layouts/MainLayout.astro';
import AdminAlerts from '../../components/admin/AdminAlerts.astro';
import AdminHeader from '../../components/admin/AdminHeader.astro';
import AdminNav from '../../components/admin/AdminNav.astro';
import ContentForm from '../../components/admin/ContentForm.astro';
import { isAdminAuthenticated } from '../../lib/adminAuth';
import { getRuntimeEnv } from '../../lib/cloudflare';
import { getSiteContent } from '../../lib/siteCms';
import { withBase } from '../../lib/urls';

export const prerender = false;

const runtimeEnv = getRuntimeEnv(Astro.locals);
if (!(await isAdminAuthenticated(Astro.cookies, runtimeEnv))) return Astro.redirect(withBase('admin?error=session'));
const content = await getSiteContent(runtimeEnv);
const error = Astro.url.searchParams.get('error');
const success = Astro.url.searchParams.get('success');
---

<MainLayout>
	<section class="min-h-screen bg-zinc-50 px-4 py-20 md:px-6">
		<div class="mx-auto max-w-7xl">
			<AdminHeader />
			<AdminAlerts error={error} success={success} />
			<div class="grid gap-6 lg:grid-cols-[220px_1fr]">
				<AdminNav active="content" />
				<main class="rounded-md border border-zinc-200 bg-white p-5 shadow-sm">
					{!content.hasDb && (
						<p class="mb-5 rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
							D1 binding DB belum tersedia. Content CMS membutuhkan binding ini.
						</p>
					)}
					{!content.hasBucket && (
						<p class="mb-5 rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
							R2 binding GALLERY_BUCKET belum tersedia. Upload gambar membutuhkan binding ini.
						</p>
					)}
					<ContentForm content={content} />
				</main>
			</div>
		</div>
	</section>
</MainLayout>

<script>
	import '../../scripts/admin-image-optimizer';
</script>
