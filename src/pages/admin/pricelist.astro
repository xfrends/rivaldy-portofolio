---
import MainLayout from '../../layouts/MainLayout.astro';
import AdminAlerts from '../../components/admin/AdminAlerts.astro';
import AdminHeader from '../../components/admin/AdminHeader.astro';
import AdminNav from '../../components/admin/AdminNav.astro';
import { isAdminAuthenticated } from '../../lib/adminAuth';
import { getRuntimeEnv } from '../../lib/cloudflare';
import { getSiteContent } from '../../lib/siteCms';
import { withBase } from '../../lib/urls';

export const prerender = false;

const runtimeEnv = getRuntimeEnv(Astro.locals);
if (!(await isAdminAuthenticated(Astro.cookies, runtimeEnv))) return Astro.redirect(withBase('admin?error=session'));
const content = await getSiteContent(runtimeEnv);
const error = Astro.url.searchParams.get('error');
const success = Astro.url.searchParams.get('success');
---

<MainLayout>
	<section class="min-h-screen bg-zinc-50 px-4 py-20 md:px-6">
		<div class="mx-auto max-w-7xl">
			<AdminHeader />
			<AdminAlerts error={error} success={success} />
			<div class="grid gap-6 lg:grid-cols-[220px_1fr]">
				<AdminNav active="pricelist" />
				<main class="rounded-md border border-zinc-200 bg-white p-5 shadow-sm">
					{!content.hasDb && (
						<p class="mb-5 rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
							D1 binding DB belum tersedia. Pricelist CMS membutuhkan binding ini.
						</p>
					)}
					<div class="flex flex-col gap-3 border-b border-zinc-200 pb-4 md:flex-row md:items-center md:justify-between">
						<div>
							<h2 class="text-2xl font-semibold">Pricelist</h2>
							<p class="text-sm text-zinc-500">{content.pricelist.length} packages</p>
						</div>
						<a href={withBase('admin/pricelist/create')} class="rounded-md bg-zinc-950 px-4 py-2 text-sm font-semibold text-white">
							Create Package
						</a>
					</div>
					<div class="divide-y divide-zinc-200">
						{content.pricelist.length === 0 ? (
							<p class="py-8 text-sm text-zinc-500">Belum ada paket pricelist.</p>
						) : (
							content.pricelist.map((pkg) => (
								<div class="grid gap-3 py-4 md:grid-cols-[1fr_100px_120px_120px] md:items-center">
									<div class="min-w-0">
										<div class="flex flex-wrap items-center gap-2">
											<p class="font-semibold text-zinc-900">{pkg.name}</p>
											{pkg.popular && <span class="rounded bg-zinc-950 px-2 py-0.5 text-xs font-semibold text-white">Popular</span>}
											{!pkg.enabled && <span class="rounded bg-zinc-100 px-2 py-0.5 text-xs font-semibold text-zinc-600">Hidden</span>}
										</div>
										<p class="text-sm text-zinc-500">/{pkg.id}</p>
										<p class="truncate text-sm text-zinc-500">{pkg.features.length} features</p>
									</div>
									<p class="text-sm font-semibold text-zinc-900">{pkg.price}</p>
									<p class="text-sm text-zinc-500">Order {pkg.sortOrder}</p>
									<a href={withBase(`admin/pricelist/${pkg.id}/edit`)} class="rounded-md border border-zinc-300 px-4 py-2 text-center text-sm font-medium text-zinc-800">
										Edit
									</a>
								</div>
							))
						)}
					</div>
				</main>
			</div>
		</div>
	</section>
</MainLayout>
