---
import MainLayout from '../layouts/MainLayout.astro';
import LandingHero from '../components/LandingHero-2.astro';
import FeaturedGallery from '../components/FeaturedGallery.astro';
import FeaturedWorkScroll from '../components/FeaturedWorkScroll.astro';
import Pricelist from '../components/Pricelist.astro';
import { getRuntimeEnv } from '../lib/cloudflare';
import { getSiteContent } from '../lib/siteCms';

export const prerender = false;

const content = await getSiteContent(getRuntimeEnv(Astro.locals));
---

<MainLayout>
	<section class="relative min-h-screen items-center flex py-20 md:py-16 overflow-hidden">
		<LandingHero content={content} />
		<FeaturedWorkScroll />
	</section>

	<section class="featured-section py-20">
		<FeaturedGallery />
	</section>

	<Pricelist />
</MainLayout>
